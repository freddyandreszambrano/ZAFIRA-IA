APP_NAME=
API_VERSION=
DEBUG=
API_DOCS_ENABLED=
API_V1_PREFIX=

# HMAC: JSON object {"client_id": "secret"}
# ZAFIRA-CORE firma cada request con su secret; debe coincidir con esta tabla.
HMAC_ALLOWED_CLIENTS=
HMAC_CLOCK_SKEW_SECONDS=

# Backend de IA: stub (passthrough, sin GPU ni red) | hosted (API estilo Replicate) | gemini
AI_BACKEND=

# Proveedor hosted (solo si AI_BACKEND=hosted)
PROVIDER_BASE_URL=
PROVIDER_API_KEY=
# Versiones concretas de modelos (ej. InstantID/PhotoMaker para avatar, CatVTON/IDM-VTON para try-on)
AVATAR_MODEL_REF=
TRYON_MODEL_REF=
PROVIDER_TIMEOUT_SECONDS=

# Gemini (solo si AI_BACKEND=gemini)
GEMINI_API_KEY=
GEMINI_MODEL=
GEMINI_BASE_URL=
GEMINI_TIMEOUT_SECONDS=

# Object storage (S3/MinIO) — bucket compartido con ZAFIRA-CORE
STORAGE_ENDPOINT_URL=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_BUCKET=
STORAGE_REGION=
