APP_NAME=ZAFIRA-IA
API_VERSION=0.1.0
DEBUG=true
API_DOCS_ENABLED=true
API_V1_PREFIX=/api/v1

# HMAC: JSON object {"client_id": "secret"}
# ZAFIRA-CORE firma cada request con su secret; debe coincidir con esta tabla.
HMAC_ALLOWED_CLIENTS='{"zafira-core":"change-me-in-production"}'
HMAC_CLOCK_SKEW_SECONDS=60

# Backend de IA: stub (passthrough, sin GPU ni red) | hosted (API estilo Replicate)
AI_BACKEND=stub

# Proveedor hosted (solo si AI_BACKEND=hosted)
PROVIDER_BASE_URL=https://api.replicate.com/v1
PROVIDER_API_KEY=r8_...
# Versiones concretas de modelos (ej. InstantID/PhotoMaker para avatar, CatVTON/IDM-VTON para try-on)
AVATAR_MODEL_REF=
TRYON_MODEL_REF=
PROVIDER_TIMEOUT_SECONDS=180

# Object storage (S3/MinIO) — bucket compartido con ZAFIRA-CORE
STORAGE_ENDPOINT_URL=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=zafira-media
STORAGE_REGION=us-east-1
